# Dependencies
/node_modules
/.pnp
.pnp.js
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Next.js build output
/.next
/out

# Build outputs
/dist
/build

# Production build files
*.tsbuildinfo
.next/*

# Environment variables (contains secrets)
.env
.env*.local
.env.*.local
.env.development
.env.production
.env.test

# Supabase service role key – never commit
.env.local

# Demo session keys (if you store them in env or as constants in code – be careful)
# This file already contains secrets; keep it out of version control.

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Reports / coverage
coverage
*.lcov
.nyc_output

# TypeScript cache
*.tsbuildinfo

# Next.js cache
.cache

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp

# Local Netlify / Vercel folders
.netlify
.vercel

# Miscellaneous
*.pem
*.cert
*.key
*.log
*.bak
*.orig

# Large public assets (if you ever store large binaries in /public, list them here)
# but your images are needed – don't ignore them unless they are generated.
# Exception: keep your /public/*.png if they are part of the source.
# If you only want to avoid committing large generated images, uncomment:
# /public/*.png
# /public/*.jpg
# /public/*.jpeg
# But you need your logo.png and dash.png – so better commit them.

# Backup files (from manual edits)
*~
*.backup
*.orig

# Python scripts and compiled Python (not relevant but sometimes appear)
__pycache__/
*.py[cod]
*.pyo
*.so

# Misc generated
*.tgz
*.tar.gz
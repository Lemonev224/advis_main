                  {overdueObligations.length} {overdueObligations.length > 1 ? t(locale, 'dashboard.regObligationsPastDue') : t(locale, 'dashboard.regObligationPastDue')}{' '}
                  {overdueObligations.slice(0, 2).map(o => o.title).join(', ')}
